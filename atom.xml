<pre><code class="language-cpp">#include&lt;stdio.h&gt;
#include&lt;math.h&gt;
long long f[71];

long long mi(long long a,long long b)
{
	if(b==0)
		return 1;
	long long ans=mi(a,b&gt;&gt;1);
	ans*=ans;
	if(b&amp;1)
		ans=ans*a;
