<p>开立方根：</p>
<pre><code class="language-cpp">#include&lt;bits/stdc++.h&gt;
#define int long long
inline int read()
{	int x=0;
	bool f=0;
	char c=getchar();
	while(!isdigit(c))f|=(c=='-'),c=getchar();
	while(isdigit(c))x=x*10+(c&amp;15),c=getchar();
	return f?-x:x;
}
using namespace std;
int a,b,bj[1000005];
inline int erfen(int x)
{	int l=0,r=1000005,ans=0;
	while(l&lt;r)
	{	int mid=(l+r)&gt;&gt;1;
		if(mid*mid*mid&lt;=x)l=mid+1,ans=mid;
		else r=mid-1;
	}
	if((ans+1)*(ans+1)*(ans+1)&lt;=x)return ans+1;
	return ans;
}
inline int get_ans(int x)
{	int maxn=erfen(x),sum=0,gs=0,maxnn=sqrt(x);
	int hou=maxnn-maxn;
	for(register int i=2;i&lt;=maxn;++i)
	{	if(bj[i])continue;
		int now=i,tp=1;
		while(now&lt;=x)
		{	gs++;
			sum+=tp;
			if(now&lt;=1000003)bj[now]=1;
			if(now&gt;maxn&amp;&amp;now&lt;=maxnn)hou--;
			if(x/now&lt;i)break;
			now=now*i;
			tp+=1;
		}
	}
	return sum+(x-gs)+hou;
}
signed main()
{	freopen(&quot;t2.in&quot;,&quot;r&quot;,stdin);
	freopen(&quot;t2.out&quot;,&quot;w&quot;,stdout);
	while(1)
	{	a=read(),b=read();
		if(a+b==0)break;
		memset(bj,0,sizeof(bj));
		int la=get_ans(a-1);
		memset(bj,0,sizeof(bj));
		int lb=get_ans(b);
		printf(&quot;%lld\n&quot;,lb-la);
	}
	return 0;
}
